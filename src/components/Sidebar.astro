---
import SocialLinks from "./SocialLinks.astro";
---

<aside class="lg:sticky lg:top-10 lg:flex lg:h-[calc(100vh-5rem)] lg:w-1/2 lg:flex-col lg:justify-between">
  <div>
    <h1 class="text-4xl font-bold tracking-tight text-slate-100 sm:text-5xl">
      Sneha Chetani
    </h1>

    <h2 class="mt-3 text-lg font-medium tracking-tight text-slate-200">
      ML Engineer / Researcher
    </h2>

    <p class="mt-4 max-w-xs leading-normal">
      My interest lies in building ML systems in the space of computational linguistics and NLP, with a focus on how LLMs and vision-language models reason, retrieve, fail, and generalize across languages, modalities, and shifting data.
    </p>

    <p class="mt-4 max-w-xs text-sm italic leading-relaxed text-emerald-300/90">
      Look closely. Build carefully.
    </p>

    <nav id="main-nav" class="relative mt-12 hidden lg:block">
        <span
            id="nav-trail"
            class="pointer-events-none absolute left-0 h-px w-10 bg-gradient-to-r from-emerald-300 to-transparent opacity-0 transition-all duration-300"
        ></span>

        <ul class="space-y-4 text-sm font-bold uppercase tracking-widest">
            <li>
                <a
                    class="nav-link block pl-16 text-slate-500 transition hover:text-emerald-300"
                    href="#about"
                    data-section="about"
                >
                    About
                </a>
            </li>

            <li>
                <a
                    class="nav-link block pl-16 text-slate-500 transition hover:text-emerald-300"
                    href="#experience"
                    data-section="experience"
                >
                    Experience
                </a>
            </li>

            <li>
                <a
                    class="nav-link block pl-16 text-slate-500 transition hover:text-emerald-300"
                    href="#projects"
                    data-section="projects"
                >
                    Projects
                </a>
            </li>

            <li>
                <a
                    class="nav-link block pl-16 text-slate-500 transition hover:text-emerald-300"
                    href="#writing"
                    data-section="writing"
                >
                    Writing
                </a>
            </li>

            <li>
                <a
                    class="nav-link block pl-16 text-slate-500 transition hover:text-emerald-300"
                    href="#contact"
                    data-section="contact"
                >
                    Contact
                </a>
            </li>
        </ul>
    </nav>
    
    <SocialLinks />

  </div>

</aside>

<script>
  import "../scripts/activeNav.ts";
</script>