---
import "../styles/global.css";
// import CursorGlow from "../components/CursorGlow.astro"; 
import ConstellationCanvas from "../components/ConstellationCanvas.astro";

const {
  title = "Sneha Chetani",
  description = "ML Engineer and NLP researcher working on retrieval, document AI, and language model evaluation.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body class="bg-slate-950 text-slate-300 antialiased">
    <ConstellationCanvas />
    <!-- <CursorGlow /> -->

    <main class="relative z-10 min-h-screen max-w-7xl px-6 py-10 md:px-16 lg:px-10">
      <slot />
    </main>
  </body>
</html>